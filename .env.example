# .env.example
# Copier ce fichier en ".env" et remplir les valeurs réelles.
# NE JAMAIS committer le fichier .env dans Git.

# --- Obligatoire en production ---
DJANGO_SECRET_KEY=remplacer-par-une-cle-aleatoire-de-50-caracteres-minimum

# --- Base de données (PostgreSQL en production) ---
# Sur Render : DATABASE_URL est injectée automatiquement — ne pas la définir manuellement.
# En dehors de Render, utiliser les variables individuelles ci-dessous.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Variables individuelles (ignorées si DATABASE_URL est définie)
DB_NAME=ensmg_comptabilite
DB_USER=ensmg_user
DB_PASSWORD=mot-de-passe-secret
DB_HOST=localhost
DB_PORT=5432

# --- Hôtes autorisés (séparés par des virgules) ---
ALLOWED_HOSTS=ensmg.sn,www.ensmg.sn

# --- Email SMTP ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@ensmg.sn
EMAIL_HOST_PASSWORD=mot-de-passe-smtp
DEFAULT_FROM_EMAIL=no-reply@ensmg.sn
